# Copy to functions/.secret.local for Firebase emulators (never commit)
# Required for emulators — do NOT put these in functions/.env (breaks deploy with defineSecret).
GEMINI_API_KEY=your-google-ai-studio-key
XAI_API_KEY=

# Comma-separated Google accounts allowed to use /admin/ (emulators only)
ADMIN_EMAILS=you@gmail.com
# Optional IP allowlist for admin callable access
# ADMIN_IP_ALLOWLIST=203.0.113.4,198.51.100.8

# Stripe — copy price IDs from Dashboard → Products (never commit real IDs)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Pro — $14.99/mo, $129/yr
# Description: 1,000 cloud minutes + 200 AI actions per month (+ unlimited on-device)
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...

# Power — $22.99/mo, $229/yr
# Description: High-volume fair use (3,000 min + generous AI) (+ unlimited on-device)
# STRIPE_PRICE_POWER_MONTHLY=price_...
# STRIPE_PRICE_POWER_YEARLY=price_...
