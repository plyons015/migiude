# Copy to functions/.secret.local for Firebase emulators (never commit)
# Required for emulators — do NOT put these in functions/.env (breaks deploy with defineSecret).
GEMINI_API_KEY=your-google-ai-studio-key
XAI_API_KEY=

# Comma-separated Google accounts allowed to use /admin/ (emulators only)
ADMIN_EMAILS=you@gmail.com
