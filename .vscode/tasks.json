{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Android: sync Capacitor",
      "type": "shell",
      "command": "npm run cap:sync",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Android: logcat (Ude errors)",
      "type": "shell",
      "command": "adb logcat -c; adb logcat *:E | findstr /i \"migiude FATAL AndroidRuntime RecordingForeground chromium\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Android: run on device",
      "type": "shell",
      "command": "npm run cap:run:android",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
