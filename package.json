{
  "name": "migiude-1",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "volta": {
    "node": "22.22.0"
  },
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "dev": "next dev",
    "build": "next build",
    "build:web": "next build",
    "start": "next start",
    "lint": "eslint",
    "cap:sync": "npm run build:web && cap sync",
    "cap:copy": "npm run build:web && cap copy",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:run:android": "npm run cap:sync && cap run android",
    "assets:android": "npx capacitor-assets generate --android",
    "emulators": "npx -y firebase-tools@latest emulators:start",
    "functions:install": "npm install --prefix functions",
    "functions:build": "npm run build --prefix functions",
    "phase0:check": "npm run build:web && npm run functions:build"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@huggingface/transformers": "^4.2.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.13.0",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
